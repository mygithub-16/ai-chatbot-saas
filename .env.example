# Application Environment (production / development)
ENVIRONMENT=production

# Database Configuration
DATABASE_URL=sqlite:///./chatbot_saas.db

# AI Engine API Keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Administrative Authentication Credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-this-admin-password
ADMIN_TOKEN_SECRET=change-this-to-a-secure-random-32char-secret
ADMIN_DASHBOARD_SECRET=change-this-to-a-secure-admin-secret-token
ADMIN_TOKEN_TTL_SECONDS=86400

# Security & CORS Settings
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173
RATE_LIMIT_PER_MINUTE=60

# Payment Gateway (Paystack)
PAYSTACK_SECRET_KEY=

# Google Calendar OAuth Integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google-calendar/callback
